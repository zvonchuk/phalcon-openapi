{
    "name": "zvonchuk/phalcon-openapi",
    "description": "Automatic OpenAPI 3.1 spec generation for Phalcon PHP — zero annotations, convention-based inference",
    "type": "library",
    "license": "MIT",
    "keywords": ["phalcon", "openapi", "swagger", "api", "documentation", "rest"],
    "homepage": "https://github.com/zvonchuk/phalcon-openapi",
    "require": {
        "php": "^8.1",
        "ext-phalcon": "^5.0"
    },
    "support": {
        "issues": "https://github.com/zvonchuk/phalcon-openapi/issues",
        "source": "https://github.com/zvonchuk/phalcon-openapi"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10 || ^2.0"
    },
    "autoload": {
        "psr-4": {
            "PhalconOpenApi\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PhalconOpenApi\\Tests\\": "tests/"
        }
    }
}
